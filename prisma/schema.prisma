generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  PLAYER
}

enum AccessScope {
  READ_ONLY
  EDIT
}

enum EquipmentCategory {
  WEAPON
  MODULE
  MISC
}

enum ProgressionCategory {
  ASPECT
  CHARACTERISTIC
  RESOURCE
  OTHER
}

enum ProgressionStatus {
  AVAILABLE
  SPENT
  LOCKED
}

enum EvolutionKind {
  ASPECT
  CHARACTERISTIC
  RESOURCE
  ARMOR
  EQUIPMENT
  NARRATIVE
}

enum ImportStatus {
  PENDING
  PARSED
  APPLIED
  FAILED
}

model User {
  id             String           @id @default(cuid())
  email          String           @unique
  name           String?
  role           Role             @default(PLAYER)
  memberships    CampaignMember[]
  characterLinks Character[]      @relation("PlayerCharacters")
  imports        FoundryImport[]  @relation("ImportAuthor")
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model Campaign {
  id         String           @id @default(cuid())
  name       String
  slug       String           @unique
  members    CampaignMember[]
  characters Character[]
  imports    FoundryImport[]
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
}

model CampaignMember {
  campaignId  String
  userId      String
  accessScope AccessScope @default(READ_ONLY)
  campaign    Campaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@id([campaignId, userId])
}

model Character {
  id                  String             @id @default(cuid())
  campaignId          String
  playerUserId        String?
  name                String
  callsign            String
  slug                String
  portraitUrl         String?
  age                 String?
  archetype           String?
  section             String?
  blazon              String?
  feat                String?
  description         String?
  history             String?
  motivations         String?
  languages           Json               @default("[]")
  distinctions        Json               @default("[]")
  healthCurrent       Int                @default(0)
  healthMax           Int                @default(0)
  hopeCurrent         Int                @default(0)
  hopeMax             Int                @default(0)
  heroismCurrent      Int                @default(0)
  heroismMax          Int                @default(0)
  aegis               Int                @default(0)
  defense             Int                @default(0)
  reaction            Int                @default(0)
  aspects             Json               @default("{}")
  characteristics     Json               @default("{}")
  foundryActorId      String?            @unique
  foundryData         Json?
  notesMj             String?
  campaign            Campaign           @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  player              User?              @relation("PlayerCharacters", fields: [playerUserId], references: [id], onDelete: SetNull)
  metaArmor           MetaArmor?
  equipment           EquipmentItem[]
  progressionBlocks   ProgressionBlock[]
  evolutionEntries    EvolutionEntry[]
  imports             FoundryImport[]
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@unique([campaignId, slug])
  @@index([campaignId])
  @@index([playerUserId])
  @@index([callsign])
}

model MetaArmor {
  id                 String    @id @default(cuid())
  characterId        String    @unique
  name               String
  generation         Int?
  armorCurrent       Int       @default(0)
  armorMax           Int       @default(0)
  forceFieldCurrent  Int       @default(0)
  forceFieldMax      Int       @default(0)
  energyCurrent      Int       @default(0)
  energyMax          Int       @default(0)
  embeddedAi         String?
  capabilities       Json      @default("[]")
  description        String?
  foundryData        Json?
  character          Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model EquipmentItem {
  id             String            @id @default(cuid())
  characterId    String
  category       EquipmentCategory
  sourceType     String?
  name           String
  sortOrder      Int               @default(0)
  equipped       Boolean           @default(false)
  quantity       Int               @default(1)
  description    String?
  tags           String[]          @default([])
  foundryItemId  String?
  foundryData    Json?
  character      Character         @relation(fields: [characterId], references: [id], onDelete: Cascade)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([characterId, category, sortOrder])
  @@index([foundryItemId])
}

model ProgressionBlock {
  id              String              @id @default(cuid())
  characterId     String
  sortOrder       Int
  label           String
  category        ProgressionCategory @default(OTHER)
  targetKey       String?
  bonusValue      Int                 @default(1)
  costXp          Int                 @default(0)
  status          ProgressionStatus   @default(AVAILABLE)
  source          String?             @default("manual")
  notes           String?
  spentAt         DateTime?
  character       Character           @relation(fields: [characterId], references: [id], onDelete: Cascade)
  evolutionEntries EvolutionEntry[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@unique([characterId, sortOrder])
  @@index([characterId, status])
}

model EvolutionEntry {
  id                 String            @id @default(cuid())
  characterId        String
  progressionBlockId String?
  kind               EvolutionKind
  targetKey          String?
  label              String
  initialValue       String?
  currentValue       String?
  gainValue          String?
  description        String?
  appliedAt          DateTime?
  character          Character         @relation(fields: [characterId], references: [id], onDelete: Cascade)
  progressionBlock   ProgressionBlock? @relation(fields: [progressionBlockId], references: [id], onDelete: SetNull)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@index([characterId])
  @@index([progressionBlockId])
}

model FoundryImport {
  id             String       @id @default(cuid())
  campaignId     String
  characterId    String?
  importedById   String?
  fileName       String?
  actorId        String?
  actorName      String?
  callsign       String?
  sourceVersion  String?
  status         ImportStatus @default(PENDING)
  rawJson        Json
  normalizedJson Json?
  errors         Json?
  campaign       Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  character      Character?   @relation(fields: [characterId], references: [id], onDelete: SetNull)
  importedBy     User?        @relation("ImportAuthor", fields: [importedById], references: [id], onDelete: SetNull)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([campaignId])
  @@index([characterId])
  @@index([actorId])
}
